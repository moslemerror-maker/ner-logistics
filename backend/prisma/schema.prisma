generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
}

enum ClaimStatus {
  PENDING
  FILED
  SETTLED
  REJECTED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())
}

model Client {
  id          Int     @id @default(autoincrement())
  name        String
  gstin       String?
  pan         String?
  address     String?
  plantName   String?
  stateCode   String?
  isInterstate Boolean @default(false)
  bills       Bill[]
}

model Bill {
  id            Int        @id @default(autoincrement())
  billNumber    String     @unique
  billDate      DateTime
  clientId      Int
  client        Client     @relation(fields: [clientId], references: [id])
  financialYear String
  totalFreight  Decimal    @db.Decimal(12, 2)
  igst          Decimal    @db.Decimal(12, 2) @default(0)
  sgst          Decimal    @db.Decimal(12, 2) @default(0)
  cgst          Decimal    @db.Decimal(12, 2) @default(0)
  grandTotal    Decimal    @db.Decimal(12, 2)
  status        String     @default("DRAFT")
  items         BillItem[]
  createdAt     DateTime   @default(now())
}

model BillItem {
  id                Int      @id @default(autoincrement())
  billId            Int
  bill              Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  slNo              Int
  consignmentNote   String?
  loadingDate       DateTime?
  loadingStation    String?
  deliveryStation   String?
  challanNo         String?
  contents          String?
  packageType       String?
  truckNumber       String?
  deliveryDate      DateTime?
  chargedWeightMt   Decimal?  @db.Decimal(10, 3)
  ratePerMt         Decimal?  @db.Decimal(10, 2)
  freightAmount     Decimal?  @db.Decimal(12, 2)
}

model Officer {
  id               Int              @id @default(autoincrement())
  name             String
  role             String?
  accountReference String?
  dispatchRecords  DispatchRecord[]
  neftPayments     NeftPayment[]
}

model DispatchRecord {
  id             Int      @id @default(autoincrement())
  biltySLNo      String?
  lrNumber       String?
  billNumber     String?
  billDate       DateTime?
  dispatchDate   DateTime?
  truckNumber    String?
  loadingPoint   String?
  destination    String?
  weightMt       Decimal?  @db.Decimal(10, 3)
  freightRate    Decimal?  @db.Decimal(10, 2)
  totalFreight   Decimal?  @db.Decimal(12, 2)
  cashAdvance    Decimal?  @db.Decimal(12, 2)
  dieselAdvance  Decimal?  @db.Decimal(12, 2)
  onlineAdvance  Decimal?  @db.Decimal(12, 2)
  totalAdvance   Decimal?  @db.Decimal(12, 2)
  balance        Decimal?  @db.Decimal(12, 2)
  billingRate    Decimal?  @db.Decimal(10, 2)
  portalBilling  Decimal?  @db.Decimal(12, 2)
  margin         Decimal?  @db.Decimal(12, 2)
  pumpName       String?
  officerId      Int?
  officer        Officer?  @relation(fields: [officerId], references: [id])
  paymentOfficer String?
  bpDate         DateTime?
  remarks        String?
  createdAt      DateTime  @default(now())
}

model NeftPayment {
  id              Int      @id @default(autoincrement())
  paymentDate     DateTime?
  biltyNumber     String?
  vehicleNumber   String?
  accountNumber   String?
  beneficiaryName String?
  amount          Decimal?  @db.Decimal(12, 2)
  ifscCode        String?
  bankName        String?
  remarks         String?
  branchName      String?
  phoneNumber     String?
  officerId       Int?
  officer         Officer?  @relation(fields: [officerId], references: [id])
  createdAt       DateTime  @default(now())
}

model PumpPayment {
  id            Int      @id @default(autoincrement())
  paymentDate   DateTime?
  accountNumber String?
  pumpName      String?
  amount        Decimal?  @db.Decimal(12, 2)
  ifscCode      String?
  bankName      String?
  location      String?
  billDated     DateTime?
  createdAt     DateTime  @default(now())
}

model DamageRecord {
  id                     Int         @id @default(autoincrement())
  incidentDate           DateTime?
  truckNumber            String?
  loadingPoint           String?
  destination            String?
  totalQty               Decimal?    @db.Decimal(10, 3)
  damagedQty             Decimal?    @db.Decimal(10, 3)
  advanceLoss            Decimal?    @db.Decimal(12, 2)
  damageCost             Decimal?    @db.Decimal(12, 2)
  otherExpenses          Decimal?    @db.Decimal(12, 2)
  materialTranship       Decimal?    @db.Decimal(12, 2)
  cementSale             Decimal?    @db.Decimal(12, 2)
  balance                Decimal?    @db.Decimal(12, 2)
  claimReceived          Decimal?    @db.Decimal(12, 2)
  recoveredFromOfficials Decimal?    @db.Decimal(12, 2)
  lossToRecover          Decimal?    @db.Decimal(12, 2)
  dispatchOfficer        String?
  incidentType           String?
  claimStatus            ClaimStatus @default(PENDING)
  remarks                String?
  createdAt              DateTime    @default(now())
}
